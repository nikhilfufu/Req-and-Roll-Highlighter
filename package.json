{
  "name": "req-n-roll-highlighter",
  "displayName": "ReqnRoll Highlighter",
  "description": "Req and Roll Highlighter - Advanced syntax highlighting and step navigation for Reqnroll/SpecFlow Gherkin features. Smart parameter highlighting, Go-to-Definition, and Cucumber Expression support for C# test automation.",
  "version": "0.0.4",
  "publisher": "nikhilgn",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhilfufu/Req-and-Roll-Highlighter.git"
  },
  "icon": "icons/logo.png",
  "readme": "README.md",
  "engines": { "vscode": "^1.74.0" },
  "activationEvents": [
    "workspaceContains:**/*.feature",
    "onLanguage:feature",
    "onLanguage:gherkin"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "feature",
        "extensions": [".feature"],
        "icon": {
          "light": "./icons/cucumber.png",
          "dark": "./icons/cucumber.png"
        }
      }
    ],
    "commands": [
      {
        "command": "bdd.copyStepSnippet",
        "title": "BDD: Copy Step Definition Snippet",
        "category": "BDD"
      },
      {
        "command": "bdd.insertStepSnippet",
        "title": "BDD: Insert Step Definition into Steps File",
        "category": "BDD"
      },
      {
        "command": "bdd.showAmbiguousMatches",
        "title": "BDD: Show Ambiguous Step Matches",
        "category": "BDD"
      },
      {
        "command": "bdd.goToDefinitionLine",
        "title": "BDD: Go To Step Definition Line",
        "category": "BDD"
      }
    ]
  }
}